---
layout: layouts/base.njk
title: "Catalogue"
permalink: "/entries/"
---

<p class="plate">Catalogue of Entries</p>

<header class="specimen">
  <h1 class="specimen__binomial">Cryptobiological Entries</h1>
  <p class="specimen__common">Classified specimens of record</p>
</header>

<ul class="catalogue-list">
  {% for entry in collections.entries %}
    <li>
      {% if entry.data.tab %}
        <span class="catalogue-list__plate" aria-label="Tab {{ entry.data.tab }}">Tab. {{ entry.data.tab | roman }}</span>
      {% else %}
        <span class="catalogue-list__plate" aria-hidden="true">&mdash;</span>
      {% endif %}
      <a href="{{ entry.url }}">
        <em>{{ entry.data.binomial or entry.data.title }}</em>{% if entry.data.common %} <span aria-hidden="true">&middot;</span> {{ entry.data.common }}{% endif %}
      </a>
    </li>
  {% endfor %}
</ul>
