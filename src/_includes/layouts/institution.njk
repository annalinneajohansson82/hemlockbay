---
layout: layouts/base.njk
---

<article class="institution" aria-labelledby="institution-title">
  <p class="plate">Institution of Record</p>

  <header class="specimen">
    <h1 id="institution-title" class="specimen__binomial">{{ name or title }}</h1>
    {% if motto %}<p class="specimen__common">{{ motto }}</p>{% endif %}
  </header>

  {{ content | safe }}
</article>
