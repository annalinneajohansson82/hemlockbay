---
layout: layouts/base.njk
---

<article class="institution">
  <p class="plate">Institution of Record</p>

  <header class="specimen">
    <h1 class="specimen__binomial">{{ name or title }}</h1>
    {% if motto %}<p class="specimen__common"{% if motto_lang %} lang="{{ motto_lang }}"{% endif %}>{{ motto }}</p>{% endif %}
  </header>

  {{ content | safe }}
</article>
