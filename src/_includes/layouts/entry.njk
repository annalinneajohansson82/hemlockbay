---
layout: layouts/base.njk
---

<article class="entry" aria-labelledby="entry-title">
  {% if tab or plate %}
    {% set _plateLabel %}{% if tab %}Tab {{ tab }}{% endif %}{% if tab and plate %}, Plate {{ plate }}{% endif %}{% if institute %}, {{ institute }}{% endif %}{% endset %}
    <p class="plate" aria-label="{{ _plateLabel | trim }}">
      {% if tab %}Tab. {{ tab | roman }}{% endif %}
      {% if tab and plate %}<span aria-hidden="true"> &middot; </span>{% endif %}
      {% if plate %}Pl. {{ plate | roman }}{% endif %}
      {% if institute %}<span aria-hidden="true"> &middot; </span>{{ institute }}{% endif %}
    </p>
  {% endif %}

  <header class="specimen">
    <h1 id="entry-title" class="specimen__binomial">{{ binomial or title }}</h1>
    {% if common %}<p class="specimen__common">{{ common }}</p>{% endif %}
  </header>

  {{ content | safe }}
</article>
